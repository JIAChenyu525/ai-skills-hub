generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Skill {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  description    String
  fullContent    String                  // complete SKILL.md content
  category       String                  // "paper" | "career" | "coding" | "exam" | "other"
  authorName     String
  authorGithub   String?
  installCommand String
  repoUrl        String?
  version        String   @default("1.0.0")
  status         String   @default("pending") // "pending" | "approved" | "rejected"
  downloads      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  githubId     String   @unique
  githubLogin  String
  githubAvatar String?
  name         String?
  email        String?
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
}
